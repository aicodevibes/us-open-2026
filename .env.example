# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CRON_SECRET: A secret key to authorize automated score updates via /api/sync.
# Set this in the AI Studio Settings -> Secrets menu.
CRON_SECRET=

# SERVICE_ACCOUNT_KEY: (Optional) JSON string of a Firebase service account key.
# If not set, the app uses Application Default Credentials (recommended for Cloud Run).
# Only needed for local development if ADC is not configured.
# SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
