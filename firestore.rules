rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model (Golf Events prefix)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email_verified == true) &&
        exists(/databases/$(database)/documents/usopen_users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/usopen_users/$(request.auth.uid)).data.role == 'admin';
    }

    // Golf Events & Subcollections: Anyone can read, only admin can write
    match /golf_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();

      match /participants/{participantId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /greedyParticipants/{participantId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /playerScores/{playerName} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /playoffScores/{playerName} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Golf Config: Anyone can read, only admin can write
    match /golf_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===============================================================
    // Legacy Rules (for fallback / compatibility)
    // ===============================================================

    // Participants: Anyone can read, only admin can write
    match /usopen_participants/{participantId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Greedy Participants: Anyone can read, only admin can write
    match /usopen_greedyParticipants/{participantId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // PlayerScores: Anyone can read, only admin can write
    match /usopen_playerScores/{playerName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PlayoffScores: Anyone can read, only admin can write
    match /usopen_playoffScores/{playerName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config: Anyone can read, only admin can write
    match /usopen_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles (for RBAC)
    match /usopen_users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
